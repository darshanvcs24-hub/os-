#include <stdio.h>

struct Process {
    int pid;
    int at;
    int bt;
    int pr;
    int ct;
    int tat;
    int wt;
    int rt;
    int completed;
};

void calculate(struct Process p[], int n)
{
    float avgwt=0,avgtat=0;

    printf("\nPID\tAT\tBT\tCT\tTAT\tWT\n");

    for(int i=0;i<n;i++)
    {
        p[i].tat = p[i].ct - p[i].at;
        p[i].wt = p[i].tat - p[i].bt;

        avgwt += p[i].wt;
        avgtat += p[i].tat;

        printf("P%d\t%d\t%d\t%d\t%d\t%d\n",
        p[i].pid,p[i].at,p[i].bt,p[i].ct,p[i].tat,p[i].wt);
    }

    printf("\nAverage Turnaround Time = %.2f", avgtat/n);
    printf("\nAverage Waiting Time = %.2f\n", avgwt/n);
}

void sjf_nonpreemptive(struct Process p[], int n)
{
    int time=0, completed=0, min_bt, index;

    while(completed != n)
    {
        min_bt = 9999;
        index = -1;

        for(int i=0;i<n;i++)
        {
            if(p[i].at <= time && p[i].completed==0 && p[i].bt < min_bt)
            {
                min_bt = p[i].bt;
                index = i;
            }
        }

        if(index != -1)
        {
            time += p[index].bt;
            p[index].ct = time;
            p[index].completed = 1;
            completed++;
        }
        else
        time++;
    }

    printf("\n--- SJF Non Preemptive ---\n");
    calculate(p,n);
}

void sjf_preemptive(struct Process p[], int n)
{
    int time=0, completed=0, min_rt, index;

    for(int i=0;i<n;i++)
    p[i].rt = p[i].bt;

    while(completed != n)
    {
        min_rt = 9999;
        index = -1;

        for(int i=0;i<n;i++)
        {
            if(p[i].at <= time && p[i].completed==0 && p[i].rt < min_rt && p[i].rt>0)
            {
                min_rt = p[i].rt;
                index = i;
            }
        }

        if(index != -1)
        {
            p[index].rt--;
            time++;

            if(p[index].rt == 0)
            {
                p[index].ct = time;
                p[index].completed = 1;
                completed++;
            }
        }
        else
        time++;
    }

    printf("\n--- SJF Preemptive ---\n");
    calculate(p,n);
}

