        for(int i=0;i<n;i++)
        {
            if(p[i].at <= time && p[i].completed==0 && p[i].pr < highest && p[i].rt>0)
            {
                highest = p[i].pr;
                index = i;
            }
        }

        if(index != -1)
        {
            p[index].rt--;
            time++;

            if(p[index].rt == 0)
            {
                p[index].ct = time;
                p[index].completed = 1;
                completed++;
            }
        }
